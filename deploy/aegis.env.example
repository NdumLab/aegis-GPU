# Aegis-GPU Production Config
# Copy to /etc/aegis-gpu/aegis.env and replace all placeholder values.
#
# Required secrets:
# - JWT_SECRET: generate with `python3 -c "import secrets; print(secrets.token_hex(32))"`
# - ADMIN_HASH / ANALYST_HASH:
#   `python3 -c "import bcrypt; print(bcrypt.hashpw(b'yourpass', bcrypt.gensalt()).decode())"`
#
# LLM mode:
# - ACTIVE_LLM=deterministic for no external provider dependency
# - ACTIVE_LLM=claude with CLAUDE_API_KEY set
# - ACTIVE_LLM=openai with OPENAI_API_KEY set

ACTIVE_LLM=deterministic
CLAUDE_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o-mini

JWT_SECRET=change-this-immediately-with-64-random-hex-characters
JWT_HOURS=8
ADMIN_HASH=change-me
ANALYST_HASH=change-me

ALLOW_DESTRUCTIVE_REMEDIATION=false
ALLOWED_ORIGINS=https://127.0.0.1,https://localhost

AEGIS_NODE_HOST=127.0.0.1
AEGIS_NODE_USERNAME=aegis

AEGIS_KB_PATH=/opt/aegis-gpu/nvidia_kb/xid_reference.json
AEGIS_AUDIT_LOG_PATH=/var/log/aegis-gpu/audit.log
AEGIS_INCIDENTS_DB=/var/lib/aegis-gpu/incidents.db
