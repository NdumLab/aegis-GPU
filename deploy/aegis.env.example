# Aegis-GPU Production Config
# Copy to /etc/aegis-gpu/aegis.env and fill in real values
ACTIVE_LLM=claude
CLAUDE_API_KEY=sk-ant-api03-YOUR-KEY-HERE
OPENAI_API_KEY=sk-YOUR-KEY-HERE
JWT_SECRET=generate: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_HASH=generate: python3 -c "import bcrypt; print(bcrypt.hashpw(b'yourpass', bcrypt.gensalt()).decode())"
ANALYST_HASH=generate: python3 -c "import bcrypt; print(bcrypt.hashpw(b'yourpass', bcrypt.gensalt()).decode())"
